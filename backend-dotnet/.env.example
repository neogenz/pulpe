# ============================================
# Pulpe .NET Backend — Environment Variables
# ============================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Or use dotnet user-secrets for local dev:
#   dotnet user-secrets init --project src/Pulpe.Api
#   dotnet user-secrets set "Supabase:Url" "http://127.0.0.1:54321"
# ============================================

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Development   # Development | Production | preview | test
PORT=3000                            # HTTP port (Railway injects this)

# --- Supabase (required) ---
Supabase__Url=http://127.0.0.1:54321
Supabase__AnonKey=your-supabase-anon-key
Supabase__ServiceRoleKey=your-supabase-service-role-key

# --- Encryption (required) ---
# 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
Encryption__MasterKey=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Cloudflare Turnstile (required in production) ---
# Skipped automatically in Development/test environments
Turnstile__SecretKey=your-turnstile-secret-key

# --- CORS (optional, production only) ---
# Comma-separated allowed origins. Vercel preview URLs are auto-allowed.
Cors__Origins=https://app.pulpe.ch

# --- Maintenance (optional) ---
# Set to "true" to return 503 on all endpoints
MAINTENANCE_MODE=false

# --- IP Blacklist (optional) ---
# Comma-separated IPs to block
IP_BLACKLIST=

# --- Debug (optional, development only) ---
# DEBUG_HTTP_FULL=true              # Log full request/response bodies
