# Variables d'environnement - Landing Pulpe
# Copiez ce fichier vers .env.local et personnalisez les valeurs

# === APP ANGULAR ===
# URL de l'app Angular - Local: http://localhost:4200 | Production: (vide, même origine)
NEXT_PUBLIC_ANGULAR_APP_URL=http://localhost:4200

# === SUPABASE (Auth Redirect) ===
# URL Supabase - Local: http://localhost:54321 | Production: https://[projet].supabase.co
# Utilisé pour détecter si l'utilisateur est connecté et le rediriger vers /dashboard
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# Clé anonyme Supabase (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# === ANALYTICS (POSTHOG) ===
# Clé publique PostHog (même projet que le frontend)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_api_key_here
# Host PostHog - En prod: /ph (reverse proxy, voir vercel.json racine)
# En local: https://eu.i.posthog.com (accès direct)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Activer le tracking (false en dev par défaut)
NEXT_PUBLIC_POSTHOG_ENABLED=false

# === INSTRUCTIONS ===
#
# LOCAL (développement)
#   - Les valeurs par défaut sont dans .env.development
#   - Créez .env.local pour des overrides personnalisés
#
# PRODUCTION
#   - Variables via Vercel dashboard
#   - NEXT_PUBLIC_ANGULAR_APP_URL vide (même domaine)
#   - NEXT_PUBLIC_SUPABASE_URL = même valeur que PUBLIC_SUPABASE_URL du frontend
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY = même valeur que PUBLIC_SUPABASE_ANON_KEY du frontend
