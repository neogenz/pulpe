# Test Environment Configuration
# Copy this file to .env.test to run integration tests

# Supabase Configuration (required for integration tests)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT Secret (required for auth tests)
JWT_SECRET=your-test-jwt-secret

# Test Configuration
NODE_ENV=test
LOG_LEVEL=silent

# Skip integration tests by default in CI
# Set CI=false to run integration tests locally
CI=true