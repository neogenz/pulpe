# Architecture

## Application Structure

```
src/
в”њв”Ђв”Ђ main.ts                 # Bootstrap with APP_INITIALIZER for config
в”њв”Ђв”Ђ app/
в”‚   в”њв”Ђв”Ђ app.ts              # Root component
в”‚   в”њв”Ђв”Ђ app.config.ts       # Application providers
в”‚   в”њв”Ђв”Ђ app.routes.ts       # Root routing
в”‚   в”њв”Ђв”Ђ core/               # Singleton services, guards, interceptors
в”‚   в”‚   в”њв”Ђв”Ђ core.ts         # Core providers export
в”‚   в”‚   в””в”Ђв”Ђ config/         # Runtime configuration
в”‚   в”њв”Ђв”Ђ feature/            # Feature modules (lazy-loaded)
в”‚   в”‚   в””в”Ђв”Ђ home/           # Example feature
в”‚   в”‚       в”њв”Ђв”Ђ home.ts
в”‚   в”‚       в””в”Ђв”Ђ home.routes.ts
в”‚   в””в”Ђв”Ђ layout/             # Layout components
в”‚       в””в”Ђв”Ђ main-layout.ts
